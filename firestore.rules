rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regras de desenvolvimento: qualquer usuário autenticado pode ler/escrever.
    // TODO: Restringir para produção com validação de memberships por query.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Analytics da plataforma (cache agregado) — apenas SuperAdmin deveria escrever.
    // Em produção, restringir write a Cloud Functions ou SuperAdmin verificado.
    match /platform_analytics/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
