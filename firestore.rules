rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserDoc() {
      return get(currentUserPath());
    }

    function membershipDocId(tenantId) {
      return tenantId + "_" + request.auth.uid;
    }

    function membershipPath(tenantId) {
      return /databases/$(database)/documents/memberships/$(membershipDocId(tenantId));
    }

    function membershipDoc(tenantId) {
      return get(membershipPath(tenantId));
    }

    function hasMembership(tenantId) {
      return isAuthenticated() && exists(membershipPath(tenantId));
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        exists(currentUserPath()) &&
        currentUserDoc().data.platform_role == 'superAdmin';
    }

    function isActiveTenantMember(tenantId) {
      return isSuperAdmin() ||
        (hasMembership(tenantId) && membershipDoc(tenantId).data.is_active == true);
    }

    function canManageTenant(tenantId) {
      return isSuperAdmin() ||
        (
          isActiveTenantMember(tenantId) &&
          (
            membershipDoc(tenantId).data.role == 'tenantAdmin' ||
            membershipDoc(tenantId).data.role == 'superAdmin'
          )
        );
    }

    match /users/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isSuperAdmin());
      allow write: if false;
    }

    match /tenants/{tenantId} {
      allow read: if isActiveTenantMember(tenantId);
      allow create: if false;
      allow update: if canManageTenant(tenantId);
      allow delete: if isSuperAdmin();

      match /customers/{customerId} {
        allow read: if isActiveTenantMember(tenantId);
        allow create, update, delete: if canManageTenant(tenantId);
      }

      match /products/{productId} {
        allow read: if isActiveTenantMember(tenantId);
        allow create, update, delete: if canManageTenant(tenantId);
      }

      match /sales/{saleId} {
        allow read: if isActiveTenantMember(tenantId);
        allow create, update: if isActiveTenantMember(tenantId);
        allow delete: if canManageTenant(tenantId);
      }

      match /escalations/{escalationId} {
        allow read: if isActiveTenantMember(tenantId);
        allow create, update: if isActiveTenantMember(tenantId);
        allow delete: if canManageTenant(tenantId);
      }

      match /stockAlerts/{alertId} {
        allow read: if isActiveTenantMember(tenantId);
        allow create, update: if isActiveTenantMember(tenantId);
        allow delete: if canManageTenant(tenantId);
      }

      match /payments/{paymentId} {
        allow read: if canManageTenant(tenantId);
        allow write: if false;
      }

      match /billing/{billingId} {
        allow read: if canManageTenant(tenantId);
        allow write: if false;
      }

      match /conversations/{conversationId} {
        allow read: if isActiveTenantMember(tenantId);
        allow create, update: if isActiveTenantMember(tenantId);
        allow delete: if canManageTenant(tenantId);
      }
    }

    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        canManageTenant(resource.data.tenant_id) ||
        isSuperAdmin()
      );
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        canManageTenant(request.resource.data.tenant_id)
      );
      allow update, delete: if isAuthenticated() && (
        isSuperAdmin() ||
        canManageTenant(resource.data.tenant_id)
      );
    }

    match /platform_analytics/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /platform_billing_plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /platform_ai_business_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
  }
}
