      "id": "12121212-1212-4121-8121-121212121212",
      "name": "Salvar Aviso",
      "credentials": {
        "googleFirebaseCloudFirestoreOAuth2Api": {
          "id": "QxD9cYkBZKwyeLQL",
          "name": "Saas Manu - Firestore OAuth2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const prev = $('Preparar Escrita').first().json;\nconst response = $input.first().json || {};\nconst alertId = prev.alert_id || (response.name ? response.name.split('/').pop() : null);\n\nreturn [{\n  json: {\n    success: true,\n    ok: true,\n    created: prev.created === true,\n    alert_id: alertId,\n    message: prev.message,\n    product_id: $('Validar Produto').first().json.product_id,\n    product_name: $('Validar Produto').first().json.product_name,\n  }\n}];"
      },
